NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/rpa_db?schema=public"
JWT_SECRET="replace-with-at-least-32-characters-secret-key"
JWT_EXPIRES_IN="1h"
INGEST_API_KEY="replace-with-a-long-random-ingest-key"
PROVISION_SECRET="replace-with-at-least-32-chars-provision-secret"
CORS_ORIGIN="http://localhost:5173"
TRUST_PROXY=0
