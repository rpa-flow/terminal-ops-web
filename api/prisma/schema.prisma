generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(254)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Record {
  id               String   @id @default(uuid()) @db.Uuid
  dataHora         DateTime @map("data_hora") @db.Timestamp(3)
  numeroNota       String   @map("numero_nota") @db.VarChar(64)
  notaOriginal     String   @map("nota_original") @db.VarChar(255)
  notaPesagemId    String   @map("nota_pesagem_id") @db.VarChar(64)
  status           String   @db.VarChar(64)
  motoristaNome    String   @map("motorista_nome") @db.VarChar(120)
  motoristaCelular String   @map("motorista_celular") @db.VarChar(24)
  placa            String   @db.VarChar(16)
  terminal         String   @db.VarChar(120)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([dataHora])
  @@index([status])
  @@index([motoristaNome])
  @@index([placa])
  @@index([terminal])
  @@map("records")
}


model PurchaseOrderRule {
  id               String   @id @default(uuid()) @db.Uuid
  materialId       String   @map("material_id") @db.VarChar(64)
  supplierId       String   @map("supplier_id") @db.VarChar(64)
  purchaseOrderCode String  @map("purchase_order_code") @db.VarChar(64)
  purchaseOrderType String  @map("purchase_order_type") @db.VarChar(32)
  description      String?  @db.VarChar(255)
  lot              String?  @db.VarChar(64)
  minimumQuantity  Decimal? @map("minimum_quantity") @db.Decimal(18, 4)
  costCenter       String?  @map("cost_center") @db.VarChar(64)
  paymentCondition String?  @map("payment_condition") @db.VarChar(64)
  currency         String?  @db.VarChar(16)
  unit             String?  @db.VarChar(16)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  createdBy        String   @map("created_by") @db.Uuid
  updatedBy        String   @map("updated_by") @db.Uuid

  histories PurchaseOrderRuleHistory[]

  @@index([materialId])
  @@index([supplierId])
  @@unique([materialId, supplierId, isActive], map: "purchase_order_rules_material_supplier_active_key")
  @@map("purchase_order_rules")
}

model PurchaseOrderRuleHistory {
  id                 String   @id @default(uuid()) @db.Uuid
  purchaseOrderRuleId String   @map("purchase_order_rule_id") @db.Uuid
  action             String   @db.VarChar(16)
  userId             String   @map("user_id") @db.Uuid
  beforeData         Json?    @map("before_data")
  afterData          Json?    @map("after_data")
  createdAt          DateTime @default(now()) @map("created_at")

  rule PurchaseOrderRule @relation(fields: [purchaseOrderRuleId], references: [id])

  @@index([purchaseOrderRuleId])
  @@map("purchase_order_rule_histories")
}
